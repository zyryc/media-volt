# =========================
# Media Vault Configuration
# =========================

# Security token used by Django to authenticate uploads/deletes
API_TOKEN=your-secret-token

# Folder where files will be stored (local disk)
STORAGE_DIR=storage

# Base URL of the Express server
# Used by Django to generate file URLs
MEDIA_VAULT_ENDPOINT=http://localhost:3000
MEDIA_VAULT_PUBLIC_URL=http://localhost:3000

# =========================
# Optional: Django-side config (if you keep it here for reference)
# =========================

MEDIA_VAULT_TOKEN=your-secret-token
